default_platform(:android)

platform :android do
  desc "Upload pre-built AAB at dist/radio-crestin-android.aab to Play Store internal testing track"
  desc "Auth: Play Console service account JSON path provided via PLAY_JSON_KEY_PATH env."
  lane :upload_play_internal do
    upload_to_play_store(
      track: "internal",
      aab: "../dist/radio-crestin-android.aab",
      json_key: ENV.fetch("PLAY_JSON_KEY_PATH"),
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: "draft",
    )
  end
end
